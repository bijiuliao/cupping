# Copy this file to .env.local and fill in your own Supabase project's values
# to switch the app from the local single-device dev backend to the real
# multi-phone backend. See README.md for the full setup steps.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: enables the "搜尋 Loffee Labs" option when adding a bean.
# loffeelabs.com has no CORS support, so the actual API key lives server-side
# as a Supabase secret, not here — see supabase/functions/loffee-proxy/index.ts
# for the one-time Edge Function deploy steps. Set this to "true" only after
# that function is deployed and its LOFFEE_API_KEY secret is set.
VITE_LOFFEE_PROXY_ENABLED=
