# Copy this file to .env.local and fill in your own Supabase project's values
# to switch the app from the local single-device dev backend to the real
# multi-phone backend. See README.md for the full setup steps.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Loffee Labs bean database API key (https://loffeelabs.com), used
# by the "搜尋 Loffee Labs" option when adding a bean. Omit to hide that option.
VITE_LOFFEE_API_KEY=
